{
  "name": "@accessbridge/core",
  "version": "0.22.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*",
    "./signals": "./src/signals/index.ts",
    "./signals/*": "./src/signals/*",
    "./decision": "./src/decision/index.ts",
    "./decision/*": "./src/decision/*",
    "./profile": "./src/profile/index.ts",
    "./profile/*": "./src/profile/*",
    "./i18n": "./src/i18n/index.ts",
    "./i18n/*": "./src/i18n/*",
    "./gestures": "./src/gestures/index.ts",
    "./gestures/*": "./src/gestures/*",
    "./audit": "./src/audit/index.ts",
    "./audit/*": "./src/audit/*",
    "./fusion": "./src/fusion/index.ts",
    "./fusion/*": "./src/fusion/*",
    "./crypto": "./src/crypto/index.ts",
    "./crypto/*": "./src/crypto/*",
    "./ipc": "./src/ipc/index.ts",
    "./ipc/*": "./src/ipc/*",
    "./vision": "./src/vision/index.ts",
    "./vision/*": "./src/vision/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
