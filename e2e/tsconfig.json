{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "types": ["node", "chrome"],
    "lib": ["ES2022", "DOM"],
    "noEmit": true
  },
  "include": ["./**/*.ts", "../playwright.config.ts"]
}
