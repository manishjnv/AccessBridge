{
  "name": "@accessbridge/core",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*",
    "./signals": "./src/signals/index.ts",
    "./signals/*": "./src/signals/*",
    "./decision": "./src/decision/index.ts",
    "./decision/*": "./src/decision/*",
    "./profile": "./src/profile/index.ts",
    "./profile/*": "./src/profile/*",
    "./i18n": "./src/i18n/index.ts",
    "./i18n/*": "./src/i18n/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
