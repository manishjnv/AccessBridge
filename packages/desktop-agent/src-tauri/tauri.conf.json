{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AccessBridge Desktop Agent",
  "version": "0.21.0",
  "identifier": "com.accessbridge.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "title": "AccessBridge Desktop Agent",
        "width": 760,
        "height": 540,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ws://127.0.0.1:* http://127.0.0.1:*"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "AccessBridge Desktop Agent"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "app", "pkg", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "Manish Kumar",
    "copyright": "Copyright (c) 2026 Manish Kumar",
    "windows": {
      "wix": {
        "language": "en-US",
        "template": null
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "providerShortName": null
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "at-spi2-core"
        ],
        "desktopTemplate": "resources/linux/accessbridge.desktop",
        "section": "utils",
        "priority": "optional",
        "files": {
          "/usr/lib/systemd/user/accessbridge.service": "resources/linux/accessbridge.service",
          "/usr/share/metainfo/io.accessbridge.Desktop.metainfo.xml": "resources/linux/io.accessbridge.Desktop.metainfo.xml"
        }
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libappindicator-gtk3",
          "at-spi2-core"
        ],
        "desktopTemplate": "resources/linux/accessbridge.desktop",
        "license": "MIT",
        "files": {
          "/usr/lib/systemd/user/accessbridge.service": "resources/linux/accessbridge.service",
          "/usr/share/metainfo/io.accessbridge.Desktop.metainfo.xml": "resources/linux/io.accessbridge.Desktop.metainfo.xml"
        }
      }
    }
  }
}
